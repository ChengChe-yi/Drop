  <Target Name="ReleaseZip" AfterTargets="CopyDropIni" Condition="'$(Configuration)'=='Release' Or '$(Configuration)'=='ReleaseMM'">
    <Message Text="Creating Release ZIP..." Importance="high" />
    <!-- Step 1: Copy files to a staging directory -->
    <MakeDir Directories="$(OutDir)zip_staging" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(OutDir)zip_staging" />
    <Copy SourceFiles="$(OutDir)\Config.ini" DestinationFolder="$(OutDir)zip_staging" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)\Whitelist\Whitelist.ini" DestinationFolder="$(OutDir)zip_staging" />
    <!-- Step 2: Create ZIP from staging -->
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;Compress-Archive -Path '$(OutDir)zip_staging\*' -DestinationPath '$(OutDir)Drop.zip' -Force&quot;" />
    <!-- Step 3: Cleanup staging -->
